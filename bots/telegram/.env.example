# Токен от @BotFather (только в .env, не коммитить)
BOT_TOKEN=123456789:AA...ваш_токен...

# Через запятую — числовые Telegram user id админов (узнать: @userinfobot)
ADMIN_IDS=123456789

# Цена в Telegram Stars
PRICE_STARS=50

PRODUCT_TITLE=AlesVPN — 30 дней
# В кавычках — иначе bash: source .env падает на скобках ()
PRODUCT_DESCRIPTION="Доступ к VPN (выдача ключа администратором после оплаты)"

# SQLite-файл с учётом оплат (по умолчанию рядом с рабочей папкой бота)
# DB_PATH=.payments.sqlite

# Юзернейм поддержки в Telegram (без @) — ссылка в /help
# SUPPORT_USERNAME=your_support

# Если с ПК не открывается api.telegram.org — прокси (Clash/v2ray и т.п.)
# TELEGRAM_PROXY=socks5://127.0.0.1:7890

# Таймаут HTTP к api.telegram.org (сек), по умолчанию 120 — при редких Request timeout
# TELEGRAM_HTTP_TIMEOUT=120

# PAYMENT_PROVIDER_TOKEN=

# --- Автовыдача WireGuard после оплаты (на том же VPS, что и wg0) ---
# WG_AUTO_PROVISION=true
# Публичный ключ СЕРВЕРА (тот же, что wg_vendor_server_public_key в Android strings.xml)
# WG_SERVER_PUBLIC_KEY=Rc1neiBkkHNmwFV/2YiWsVJyEc9V0rQm03QnMaWR7Qs=
# WG_ENDPOINT=5.42.122.172:51820
# Скрипт из репозитория server/wg-add-peer.sh (chmod +x, запуск от root)
# WG_ADD_PEER_SCRIPT=/usr/local/bin/wg-add-peer.sh
# WG_BINARY=wg
# WG_DNS=1.1.1.1
# WG_ALLOWED_IPS=0.0.0.0/0, ::/0
# WG_KEEPALIVE=25
# Первые три октета VPN-подсети (как на сервере в wg0)
# WG_SUBNET_PREFIX=10.8.0
# Пул клиентских адресов 10.8.0.N — только N (не пересекайте с уже выданными IP)
# WG_OCTET_MIN=20
# WG_OCTET_MAX=250
