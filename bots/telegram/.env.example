# Токен от @BotFather (только в .env, не коммитить)
BOT_TOKEN=123456789:AA...ваш_токен...

# Через запятую — числовые Telegram user id админов (узнать: @userinfobot)
ADMIN_IDS=123456789

# Цена в Telegram Stars
PRICE_STARS=50

PRODUCT_TITLE=AlesVPN — 30 дней
PRODUCT_DESCRIPTION=Доступ к VPN (выдача ключа администратором после оплаты).

# Если с ПК не открывается api.telegram.org — прокси (Clash/v2ray и т.п.)
# TELEGRAM_PROXY=socks5://127.0.0.1:7890

# PAYMENT_PROVIDER_TOKEN=
