# Скопируй в keystore.properties (рядом с app/build.gradle.kts — каталог mobile/android)
# и заполни после keytool. Файл keystore.properties в git не коммитить.
#
# keytool -genkey -v -keystore release.keystore -alias alesvpn -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=alesvpn
keyPassword=CHANGE_ME
